{
  "camera": {
    "device_id": 1,
    "width": 640,
    "height": 480,
    "fps": 60,
    "buffer_size": 1,
    "backend": "dshow"
  },
  "video": {
    "codec": "mp4v",
    "output_width": null,
    "output_height": null
  },
  "display": {
    "window_name_original": "Darwin Original",
    "window_name_processed": "Darwin Processed",
    "show_fps": true,
    "scale_factor": 1.0,
    "show_original": true,
    "show_processed": true,
    "http": {
      "base_url": "http://172.18.20.118:9000",
      "endpoint": "/process/frame_yolo",
      "timeout": 10,
